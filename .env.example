# ── Database ──────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/real_estate_os
DATABASE_SYNC_URL=postgresql://postgres:postgres@localhost:5432/real_estate_os
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_ECHO=false

# ── App ───────────────────────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8000
APP_DEBUG=true
APP_TITLE=Real Estate OS API
APP_VERSION=0.2.0
APP_DESCRIPTION=AI-платформа для агентства недвижимости

# ── Security ──────────────────────────────────────────────────
# REQUIRED: set a strong random value here
SECRET_KEY=change-me-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=1440
JWT_ALGORITHM=HS256

# ── Telegram (optional — for bot integration) ─────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_API_ID=0
TELEGRAM_API_HASH=
REVIEW_GROUP_CHAT_ID=

# ── AI Models ─────────────────────────────────────────────────
AI_QWEN_ENDPOINT=http://localhost:8001/v1
AI_DEEPSEEK_FLASH=deepseek-chat
AI_DEEPSEEK_PRO=deepseek-reasoner
# REQUIRED: set your OpenAI API key for ChatGPT fallback
AI_CHATGPT_API_KEY=
AI_EMBEDDING_MODEL=intfloat/multilingual-e5-small

# ── Lead Scoring (optional — for Lead Engine) ─────────────────
LEAD_SCORE_RULE_HOT=0.80
LEAD_SCORE_RULE_WARM=0.60
LEAD_SCORE_RULE_COLD=0.30
LEAD_AUTO_ASSIGN_THRESHOLD=0.80
LEAD_EXPIRY_DAYS=30
LEAD_MAX_REOPEN=3

# ── Integrations (optional — for external platforms) ──────────
AVITO_API_KEY=
CIAN_API_KEY=
